# Канонический URL самой тест-платформы — используется в metadataBase,
# sitemap.xml, robots.txt и OG-картинках. Фолбэк — https://tests.marsel.ru
NEXT_PUBLIC_SITE_URL=https://tests.marsel.ru

# URL основного лендинга — используется для CTA "Записаться к специалисту"
NEXT_PUBLIC_LANDING_URL=https://marsel.ru
NEXT_PUBLIC_SPECIALIST_NAME=Марсель
# Дательный падеж имени — для фразы "Записаться к ___у".
# Если не задано: для "Марсель" вернётся "Марселю", иначе — "<name>у".
NEXT_PUBLIC_SPECIALIST_NAME_DATIVE=Марселю
